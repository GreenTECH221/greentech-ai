---
interface Props {
  title?: string;
  subtitle?: string;
}

const { title = 'GreenTECH', subtitle = 'Three platforms. One mission. Transforming South Africa\'s fresh produce industry through technology, transparency, and collective ownership.' } = Astro.props;
---

<section class="gradient-hero relative overflow-hidden">
  <!-- Subtle grid pattern -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot;%3E%3Cpath d=&quot;M60 0v60H0&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40">
    <div class="max-w-3xl">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent/10 border border-accent/20 mb-6">
        <div class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></div>
        <span class="text-xs font-medium text-accent">Green Technologies Holdco (Pty) Ltd</span>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white tracking-tight mb-6">
        {title}
      </h1>
      <p class="text-lg sm:text-xl text-gray-400 leading-relaxed max-w-2xl">
        {subtitle}
      </p>

      <!-- Quick nav pills -->
      <div class="flex flex-wrap gap-3 mt-10">
        <a href="#platforms" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-accent text-white text-sm font-medium hover:bg-accent-light transition-colors">
          View Platforms
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
        <a href="/about" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-white/10 text-gray-300 text-sm font-medium hover:bg-white/5 hover:text-white transition-colors">
          About GreenTECH
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-surface to-transparent"></div>
</section>
