---
interface Props {
  name: string;
  tagline: string;
  description: string;
  href: string;
  appUrl: string;
  color: string;
  icon: string;
}

const { name, tagline, description, href, appUrl, color, icon } = Astro.props;

const icons: Record<string, string> = {
  building: 'M3 21h18M3 7v14M21 7v14M6 11h.01M6 15h.01M6 19h.01M10 11h.01M10 15h.01M10 19h.01M14 11h.01M14 15h.01M14 19h.01M18 11h.01M18 15h.01M18 19h.01M3 7l9-4 9 4',
  cog: 'M12 15a3 3 0 100-6 3 3 0 000 6zM19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z',
  rocket: 'M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 00-2.91-.09zM12 15l-3-3M22 2l-7.59 7.59M15 2H22V9M22 2L13.5 10.5',
};

const iconPath = icons[icon] || icons.building;
---

<a href={href} class="card-hover block relative group rounded-xl border border-white/5 bg-surface-raised p-6 overflow-hidden">
  <!-- Glow effect -->
  <div class="platform-glow" style={`background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), ${color}08, transparent 40%);`}></div>

  <!-- Icon -->
  <div class="relative w-12 h-12 rounded-lg flex items-center justify-center mb-4" style={`background: ${color}15;`}>
    <svg class="w-6 h-6" style={`color: ${color};`} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
    </svg>
  </div>

  <!-- Content -->
  <div class="relative">
    <h3 class="text-lg font-bold text-white mb-1">{name}</h3>
    <p class="text-sm font-medium mb-3" style={`color: ${color};`}>{tagline}</p>
    <p class="text-sm text-gray-400 leading-relaxed mb-5">{description}</p>

    <div class="flex items-center gap-3">
      <span class="inline-flex items-center gap-1.5 text-sm font-medium text-white group-hover:text-accent transition-colors">
        Learn more
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </span>
      <a href={appUrl} target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full border border-white/10 text-gray-400 hover:text-white hover:border-white/20 transition-colors"
         onclick="event.stopPropagation();">
        Launch app
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" />
        </svg>
      </a>
    </div>
  </div>
</a>
