---
const platforms = [
  { name: 'AlterMARKt', href: 'https://rsa-hub-identity.web.app', color: 'text-altermarkt' },
  { name: 'RSA X', href: 'https://forkflex-39ce1.web.app', color: 'text-forkflex' },
  { name: 'RSA SupaSales', href: 'https://rsa-beyond.web.app', color: 'text-beyond' },
];
---

<footer class="border-t border-white/5 bg-surface">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Brand -->
      <div class="flex items-center gap-2.5">
        <div class="w-7 h-7 rounded-md bg-accent flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <span class="text-sm font-semibold text-gray-400">Green Technologies Holdco (Pty) Ltd</span>
      </div>

      <!-- Platform Links -->
      <div class="flex items-center gap-6">
        {platforms.map(p => (
          <a href={p.href} target="_blank" rel="noopener noreferrer" class={`text-sm font-medium text-gray-500 hover:${p.color} transition-colors`}>
            {p.name}
          </a>
        ))}
      </div>

      <!-- Meta -->
      <p class="text-xs text-gray-600">&copy; {new Date().getFullYear()} GreenTECH &middot; Internal Use Only</p>
    </div>
  </div>
</footer>
