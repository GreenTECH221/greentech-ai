---
import Base from '../layouts/Base.astro';
import PlatformHero from '../components/PlatformHero.astro';
---

<Base title="RSA Beyond (SupaSales) — GreenTECH" description="RSA Beyond: B2B trading marketplace and farmer/agent investment portal for South Africa's fresh produce industry.">
  <PlatformHero
    name="RSA Beyond"
    tagline="B2B Trading Marketplace & Investment Portal"
    color="#F59E0B"
    appUrl="https://rsa-beyond.web.app"
  />

  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="prose-custom">
        <h2 class="text-2xl font-bold text-white mb-4">The Marketplace</h2>
        <p class="text-gray-400 leading-relaxed mb-8">
          RSA Beyond is the customer-facing layer of the AlterMARKt ecosystem. It connects farmers directly with buyers and agents through a transparent B2B trading marketplace, eliminating information asymmetry and enabling fair price discovery.
        </p>

        <h2 class="text-2xl font-bold text-white mb-4">Two Core Functions</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-8">
          <div class="p-6 rounded-lg bg-surface-raised border border-white/5">
            <div class="w-10 h-10 rounded-lg bg-beyond/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-beyond" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">B2B Trading</h3>
            <p class="text-sm text-gray-400 leading-relaxed">Direct marketplace for fresh produce trading. Real-time pricing, quality grading, logistics coordination, and settlement &mdash; all in one platform.</p>
          </div>
          <div class="p-6 rounded-lg bg-surface-raised border border-white/5">
            <div class="w-10 h-10 rounded-lg bg-beyond/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-beyond" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-white mb-2">Investment Portal</h3>
            <p class="text-sm text-gray-400 leading-relaxed">Farmer and agent access to their equity positions in the Farmer's Fund and Agency's Fund. Track contributions, view pro-rata holdings, and monitor fund performance.</p>
          </div>
        </div>

        <h2 class="text-2xl font-bold text-white mb-4">How It Connects</h2>
        <p class="text-gray-400 leading-relaxed mb-6">
          RSA Beyond is the external face of an integrated system. Behind the scenes:
        </p>
        <div class="space-y-3 mb-8">
          <div class="flex items-start gap-3 p-4 rounded-lg bg-surface-raised border border-white/5">
            <span class="text-xs font-bold text-beyond bg-beyond/10 px-2 py-1 rounded shrink-0">TRADE</span>
            <p class="text-sm text-gray-400">Sales data flows to ForkFlex for commission processing, inventory updates, and compliance reporting.</p>
          </div>
          <div class="flex items-start gap-3 p-4 rounded-lg bg-surface-raised border border-white/5">
            <span class="text-xs font-bold text-beyond bg-beyond/10 px-2 py-1 rounded shrink-0">INVEST</span>
            <p class="text-sm text-gray-400">1% of farmer sales auto-contributes to the Farmer's Fund. 2% of agent revenue goes to the Agency's Fund. Both tracked transparently.</p>
          </div>
          <div class="flex items-start gap-3 p-4 rounded-lg bg-surface-raised border border-white/5">
            <span class="text-xs font-bold text-beyond bg-beyond/10 px-2 py-1 rounded shrink-0">IDENTITY</span>
            <p class="text-sm text-gray-400">User identity and facility registration managed through AlterMARKt (RSA-Hub-Identity).</p>
          </div>
        </div>

        <h2 class="text-2xl font-bold text-white mb-4">Tech Stack</h2>
        <div class="flex flex-wrap gap-2">
          {['Flutter 3.x', 'Firebase', 'Firestore', 'Cloud Functions', 'PWA', 'Dark UI', 'Real-time Data'].map(tag => (
            <span class="px-2.5 py-1 text-xs font-mono font-medium rounded bg-beyond/10 text-beyond">{tag}</span>
          ))}
        </div>
      </div>
    </div>
  </section>
</Base>
