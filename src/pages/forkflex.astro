---
import Base from '../layouts/Base.astro';
import PlatformHero from '../components/PlatformHero.astro';
---

<Base title="RSA X — GreenTECH" description="RSA X: The AI-Enabled Business Orchestrator powering AlterMARKt facility operations with dual-AI architecture and WhatsApp Voice control.">
  <PlatformHero
    name="RSA X"
    tagline="AI-Enabled Business Orchestrator"
    color="#6366F1"
    appUrl="https://forkflex-39ce1.web.app"
  />

  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="prose-custom">
        <h2 class="text-2xl font-bold text-white mb-4">What It Does</h2>
        <p class="text-gray-400 leading-relaxed mb-8">
          RSA X is the AI-enabled operational management platform for AlterMARKt facilities. It orchestrates every aspect of facility operations: sales processing, commission calculations, inventory management, HR, fleet, maintenance, and compliance reporting.
        </p>

        <h2 class="text-2xl font-bold text-white mb-4">Dual-AI Architecture</h2>
        <p class="text-gray-400 leading-relaxed mb-6">
          RSA X runs a dual-AI system combining Google Gemini and Anthropic Claude. Each AI handles different operational domains, with function calling and structured output for reliable, auditable automation.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
          <div class="p-5 rounded-lg bg-surface-raised border border-white/5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-forkflex/10 flex items-center justify-center">
                <span class="text-xs font-bold text-forkflex">G</span>
              </div>
              <p class="font-semibold text-white">Google Gemini</p>
            </div>
            <p class="text-sm text-gray-400">Operational AI &mdash; structured data processing, form generation, compliance checks, real-time calculations.</p>
          </div>
          <div class="p-5 rounded-lg bg-surface-raised border border-white/5">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-forkflex/10 flex items-center justify-center">
                <span class="text-xs font-bold text-forkflex">C</span>
              </div>
              <p class="font-semibold text-white">Anthropic Claude</p>
            </div>
            <p class="text-sm text-gray-400">Intelligence AI &mdash; natural language analysis, document review, strategic insights, conversational interface.</p>
          </div>
        </div>

        <h2 class="text-2xl font-bold text-white mb-4">24 Working AI Features</h2>
        <p class="text-gray-400 leading-relaxed mb-6">
          Not roadmap promises &mdash; 24 production AI features including WhatsApp Voice control for hands-free facility management, real-time business intelligence dashboards, and automated compliance reporting.
        </p>

        <h2 class="text-2xl font-bold text-white mb-4">Operational Divisions</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-8">
          {['Sales & Trading', 'Commission Engine', 'Inventory', 'HR & Payroll', 'Fleet Management', 'Maintenance', 'Compliance', 'Finance', 'Analytics'].map(div => (
            <div class="p-3 rounded-lg bg-surface-raised border border-white/5 text-center">
              <span class="text-sm text-gray-300">{div}</span>
            </div>
          ))}
        </div>

        <h2 class="text-2xl font-bold text-white mb-4">Tech Stack</h2>
        <div class="flex flex-wrap gap-2">
          {['Flutter 3.x', 'Firebase', 'Gemini API', 'Claude API', 'Cloud Functions', 'Firestore', 'PWA', 'Dark UI'].map(tag => (
            <span class="px-2.5 py-1 text-xs font-mono font-medium rounded bg-forkflex/10 text-forkflex">{tag}</span>
          ))}
        </div>
      </div>
    </div>
  </section>
</Base>
